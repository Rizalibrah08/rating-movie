{
    "framework": null,
    "buildCommand": "npm run build:ssr",
    "outputDirectory": "public/build",
    "installCommand": "npm ci",
    "devCommand": "npm run dev",
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ],
    "headers": [
        {
            "source": "/build/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
